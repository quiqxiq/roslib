# roslib environment variables — copy ke .env dan isi.
# Dipakai oleh config.LoadFromEnv() (lihat config/config.go).

# ── Router (wajib, single-router mode) ─────────────────────────
ROSLIB_ROUTER_ADDRESS=192.168.230.2:8728
ROSLIB_ROUTER_USERNAME=admin
ROSLIB_ROUTER_PASSWORD=r00t
# ROSLIB_ROUTER_ID=rb1               # optional, fallback ke address

# ── Fleet mode (multi-router) ──────────────────────────────────
# Aktifkan dengan ROSLIB_ROUTERS=id1,id2,...
# Per-router config pakai prefix ROSLIB_ROUTER_<ID-UPPER>_*.
# Dash di ID otomatis di-translate ke underscore.
#
ROSLIB_ROUTERS=rb1,rb2
ROSLIB_ROUTER_RB1_ADDRESS=192.168.233.1:8728
ROSLIB_ROUTER_RB1_USERNAME=admin
ROSLIB_ROUTER_RB1_PASSWORD=r00t
ROSLIB_ROUTER_RB2_ADDRESS=192.168.230.2:8728
ROSLIB_ROUTER_RB2_USERNAME=admin
ROSLIB_ROUTER_RB2_PASSWORD=r00t
# ROSLIB_ROUTER_OFFICE_GW_ADDRESS=10.0.0.1:8728      # "office-gw" → OFFICE_GW
# ROSLIB_ROUTER_OFFICE_GW_USERNAME=admin
# ROSLIB_ROUTER_OFFICE_GW_PASSWORD=secret
# ROSLIB_ROUTER_TLS=false
# ROSLIB_ROUTER_INSECURE_SKIP_VERIFY=false

# ── Connection tuning (opsional) ───────────────────────────────
# ROSLIB_DIAL_TIMEOUT=10s
# ROSLIB_LISTEN_QUEUE_SIZE=100
# ROSLIB_RECONNECT_INITIAL=500ms
# ROSLIB_RECONNECT_MAX=30s
# ROSLIB_RECONNECT_MAX_ELAPSED=0    # 0 = retry selamanya

# ── Cache (opsional) ───────────────────────────────────────────
ROSLIB_CACHE_ENABLED=true
ROSLIB_CACHE_TTL=30s
# ROSLIB_CACHE_ADDR=127.0.0.1:6379
# ROSLIB_CACHE_PASSWORD=
# ROSLIB_CACHE_DB=0

# ── InfluxDB3 sink (opsional) ──────────────────────────────────
ROSLIB_INFLUX_ENABLED=true
INFLUX_HOST=http://127.0.0.1:8181
INFLUX_DATABASE=mikrotik
INFLUX_TOKEN=no-auth-dev-mode
# INFLUX_ORG=
# ROSLIB_INFLUX_MEASUREMENT=roslib
